{
    "include": [
        "react/features/**/*.ts",
        "react/features/**/*.tsx",
        "react/components/**/*.ts",
        "react/components/**/*.tsx",
        "lib/**/*.ts",
        "./custom.d.ts",
        "./globals.d.ts"
    ],
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "module": "es2020",
        "target": "es2024",
        "jsx": "react",
        "lib": [ "ES2024", "DOM" ],
        "skipLibCheck": true,
        "moduleResolution": "Node",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "strictPropertyInitialization": false,
        "paths": {
            "@/*": [ "./*" ]
        },
        "resolveJsonModule": true,
        "moduleSuffixes": [".web", ""]
    },
    "exclude": [
        "node_modules",
        "react/features/share-room",
        "**/mobile/*",
        "**/native/*",
        "**/*.native.ts",
        "**/*.native.tsx",
        "**/*.ios.ts",
        "**/*.android.ts"
    ]
}
